# Copy to .env.local for local development. Never commit real secrets.
# Every value here is a placeholder. Production values live only in the
# hosting platform's secret manager.

# --- Site ---
# Public base URL of the deployment (used for canonical URLs, sitemaps, OG tags).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Set to "true" only when the client has approved go-live. While "false" the
# site stays noindex and the staging access gate is active.
SITE_INDEXABLE="false"
# Password for the staging access gate (kept until go-live).
STAGING_ACCESS_PASSWORD=""

# --- Database (managed PostgreSQL, EU region) ---
# When unset, development and tests use an in-process PostgreSQL (PGlite).
DATABASE_URL="postgresql://user:password@host:5432/knotten?sslmode=require"

# --- Lead capture ---
# Long random salt used to hash IP addresses for abuse control (no raw IP is
# stored). Generate with: openssl rand -base64 32
IP_HASH_SALT=""
# Shared secret for the retention cron endpoint (POST /api/cron/retention,
# Authorization: Bearer <secret>). Generate with: openssl rand -base64 32
CRON_SECRET=""

# --- Admin authentication ---
# Long random secret for session signing. Generate with: openssl rand -base64 32
AUTH_SECRET=""
# One-time secret to provision the first admin operator via POST /admin/bootstrap
# (there is no public sign-up). Generate with: openssl rand -base64 32. Unset it
# again after the owner account exists.
ADMIN_BOOTSTRAP_SECRET=""

# --- Transactional email (EU/EEA provider) ---
EMAIL_API_KEY=""
EMAIL_FROM="Knotten <ingen-svar@example.no>"
EMAIL_ADMIN_NOTIFY="" # address that receives new-lead notifications

# --- Observability (optional, wired at go-live) ---
# EU-region error tracker DSN (e.g. Sentry EU / GlitchTip). PII is never sent.
# Leave empty to log errors to stdout only.
ERROR_TRACKING_DSN=""

# --- Analytics (Plausible, EU, cookieless) ---
# The site domain registered in Plausible. While unset, no analytics script
# loads (development and previews stay clean, no goals fire).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
# Optional: override the script URL to a self-hosted or proxied Plausible
# endpoint. Defaults to the EU tagged-events build on plausible.io.
NEXT_PUBLIC_PLAUSIBLE_SRC=""

# --- Bot mitigation (Cloudflare Turnstile) ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# --- Maps and terrain (no key needed for OpenStreetMap; tile provider optional) ---
NEXT_PUBLIC_MAP_TILE_URL=""

# --- Content image uploads ---
# Directory the content image uploads are written to. Defaults to public/uploads
# in development. In production point this at a mounted EU volume, or swap the
# storage adapter in src/lib/content/storage.ts for an EU object-storage client.
UPLOAD_DIR=""
