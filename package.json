    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.20.0",
    "next": "16.2.9",
    "next-intl": "^4.13.0",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "suncalc": "1.9.0",
    "tailwind-merge": "^3.6.0",
    "three": "0.180.0",
    "zod": "^4.4.3"
