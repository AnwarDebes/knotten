    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.9",
    "geotiff": "2.1.3",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "jsdom": "^26.0.0",
    "lint-staged": "^16.0.0",
    "playwright": "1.61.0",
    "prettier": "^3.4.2",
